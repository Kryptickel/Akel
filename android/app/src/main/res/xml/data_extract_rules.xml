
<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!--
    Data extraction rules for Android 12+
    Controls what data can be transferred between devices
    -->

    <cloud-backup>
        <!-- Include app data for cloud backup -->
        <include domain="sharedpref" path="."/>
        <include domain="database" path="."/>
        <include domain="file" path="."/>

        <!-- Exclude sensitive emergency data -->
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
        <exclude domain="database" path="secure.db"/>
        <exclude domain="file" path="recordings/"/>
        <exclude domain="file" path="evidence/"/>
    </cloud-backup>

    <device-transfer>
        <!-- Include data for device-to-device transfer -->
        <include domain="sharedpref" path="."/>
        <include domain="database" path="."/>

        <!-- Exclude sensitive data from transfer -->
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
        <exclude domain="database" path="secure.db"/>
    </device-transfer>
</data-extraction-rules>