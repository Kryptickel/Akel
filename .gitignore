# ==================== AKEL PANIC BUTTON .gitignore ====================
# Prevents sensitive data from being committed to GitHub
# ======================================================================

# ===== CRITICAL: DO NOT COMMIT THESE =====
# API Keys & Secrets
.env
.env.local
.env.production
*.key
*.pem
secrets/
config/private/

# Firebase Configuration (contains API keys)
google-services.json
GoogleService-Info.plist
firebase-adminsdk-*.json

# ===== Flutter/Dart =====
# Build outputs
**/build/
**/android/app/build/
**/ios/build/
**/web/build/

# Flutter specific
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
pubspec.lock

# ===== Android =====
*.iml
.gradle
local.properties
.idea/
*.hprof
*.ap_
*.dex
*.class

# Android Keystore (NEVER commit these!)
*.jks
*.keystore
key.properties

# ===== iOS =====
**/ios/Flutter/flutter_export_environment.sh
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/.generated/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
xcuserdata/
*.moved-aside
*.xccheckout
*.xcscmblueprint

# ===== IDE =====
# Android Studio
.idea/
*.iml
.gradle/
local.properties

# VS Code
.vscode/

# ===== macOS =====
.DS_Store
.AppleDouble
.LSOverride

# ===== Windows =====
Thumbs.db
Desktop.ini

# ===== Log Files =====
*.log

# ===== Temporary Files =====
*.tmp
*.temp
*.swp
*.swo
*~

# ===== Sensitive User Data =====
# Don't commit user databases or credentials
*.db
*.sqlite
*.sqlite3
credentials.json
auth_token.txt

# ===== Large Files =====
# Don't commit large media files
*.mp4
*.mov
*.avi
*.mkv
# (unless they're small assets needed for app)
